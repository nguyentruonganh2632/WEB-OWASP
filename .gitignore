# ─── Biến môi trường (chứa password, secret key) ───────────
.env
backend/.env
frontend/.env
# Giữ lại file mẫu để người clone biết cần điền gì
!.env.example

# ─── Python ─────────────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
