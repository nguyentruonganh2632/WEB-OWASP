backend/**/*.pyo

# ─── Node / Frontend ────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# ─── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.log

# ─── Uploads / Temp ─────────────────────────────────────────
backend/uploads/
backend/temp/
